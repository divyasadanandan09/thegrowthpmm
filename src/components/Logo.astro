---
// Brand logo: the "sharpened funnel" mark on a lime badge (lime + near-black
// palette) plus the wordmark. From the brand kit.
interface Props {
  size?: number; // mark height in px
  wordSize?: number; // wordmark font-size in px
  variant?: "navy" | "reverse"; // wordmark tone: dark on light, white on dark
}
const { size = 28, wordSize = 16, variant = "navy" } = Astro.props;
const word = variant === "reverse" ? "#ffffff" : "var(--ink)";
---

<span style="display:inline-flex;align-items:center;gap:9px;">
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" aria-hidden="true" style="flex:none;display:block;">
    <rect width="40" height="40" rx="9" fill="#DBFF00"></rect>
    <g transform="translate(7,7) scale(0.65)">
      <path d="M5 6h30l-4.5 6.6H9.5z" fill="#16180f"></path>
      <path d="M11 15.4h18l-4 6.1H15z" fill="#16180f" opacity="0.7"></path>
      <path d="M16.5 24.3h7l-1.6 5.3h-3.8z" fill="#16180f" opacity="0.44"></path>
      <circle cx="20" cy="35" r="2.7" fill="#cc4117"></circle>
    </g>
  </svg>
  <span style={`font-weight:800;font-size:${wordSize}px;letter-spacing:-0.3px;color:${word};`}>The Growth PMM</span>
</span>
