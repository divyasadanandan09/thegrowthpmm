---
// Brand logo: the "sharpened funnel" mark (three tapering bars + the warm
// leak dot) plus the wordmark. From the brand kit.
interface Props {
  size?: number; // mark height in px
  wordSize?: number; // wordmark font-size in px
  variant?: "navy" | "reverse"; // navy on light, reverse (white) on navy
}
const { size = 28, wordSize = 16, variant = "navy" } = Astro.props;
const bar = variant === "reverse" ? "#ffffff" : "#1b2a6b";
const dot = variant === "reverse" ? "#ffb59e" : "#cc4117";
const word = variant === "reverse" ? "#ffffff" : "var(--ink)";
---

<span style="display:inline-flex;align-items:center;gap:9px;">
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" aria-hidden="true" style="flex:none;display:block;">
    <path d="M5 6h30l-4.5 6.6H9.5z" fill={bar}></path>
    <path d="M11 15.4h18l-4 6.1H15z" fill={bar} opacity="0.7"></path>
    <path d="M16.5 24.3h7l-1.6 5.3h-3.8z" fill={bar} opacity="0.44"></path>
    <circle cx="20" cy="35" r="2.7" fill={dot}></circle>
  </svg>
  <span style={`font-weight:800;font-size:${wordSize}px;letter-spacing:-0.3px;color:${word};`}>The Growth PMM</span>
</span>
