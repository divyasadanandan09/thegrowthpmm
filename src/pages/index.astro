---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
const BOOKING = "https://calendar.app.google/LXLo1623kmwa7NWr6";
// TODO: replace with the real Growth Audit Google Form URL before launch.
const DIAGNOSTIC = "https://forms.gle/HTwdNSTiyyXQYsxb7";
---

<Layout>

<!-- NAV: full bar at top of page, collapses to a corner CTA on scroll -->
<div class="nav-wrap" id="nav-top">
  <div id="navbar">
    <a href="#top" style="display:flex;align-items:center;flex:none;text-decoration:none;">
      <Logo size={28} wordSize={16} />
    </a>
    <div id="nav-links">
      <a href="#report">Growth Audit</a>
      <a href="#services">Services</a>
      <a href="#about">About me</a>
    </div>
    <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="font-size:13px;padding:9px 18px;flex:none;">Book a call</a>
    <button id="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2 5h16M2 10h16M2 15h16" stroke="#1b2a6b" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>
</div>
<div id="mobile-menu">
  <a href="#report">Growth Audit</a>
  <a href="#services">Services</a>
  <a href="#proof">Proof</a>
  <a href="#about">About me</a>
  <a href="/ai-product-marketing">AI PMM</a>
  <a href="/faq">FAQ</a>
  <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="text-align:center;margin-top:8px;padding:12px;">Book a call</a>
</div>
<div id="nav-cta-corner">
  <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy">Book a call</a>
</div>
<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!isOpen));
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => menu.classList.remove("open"))
  );
  const onScroll = () => {
    document.body.classList.toggle("scrolled", window.scrollY > 80);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // Respect reduced-motion: SMIL can't be gated by CSS, so freeze the funnel
  // animations on the first frame for users who opt out.
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const applyMotionPref = () => {
    if (!reduceMotion.matches) return;
    const svg = document.querySelector(".funnel-wrap svg");
    if (svg && typeof svg.pauseAnimations === "function") svg.pauseAnimations();
  };
  reduceMotion.addEventListener("change", applyMotionPref);
  applyMotionPref();
</script>

<main>
<!-- HERO -->
<header id="top" class="grid-canvas" style="background:var(--hero-bg);position:relative;overflow:hidden;">
  <div class="hero-grid" style="max-width:1240px;margin:0 auto;padding:140px 24px 80px;display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center;position:relative;">
    <div>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px;">
        <span class="sticky-tag purple">Fractional Head of PMM</span>
        <span class="sticky-tag gold">Top 100 PMM, 2025</span>
      </div>
      <h1 style="font-size:54px;font-weight:800;line-height:1.08;letter-spacing:-1.4px;margin:0;color:var(--ink);">You have paying users, but growth stalled?<br /><span style="display:block;font-size:0.96em;color:var(--navy);margin-top:6px;">I'll find what's capping it and fix it.</span></h1>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-mute);margin:18px 0 0;max-width:560px;">Bring me in as your fractional Head of Product Marketing. I find what's capping growth, whether it's positioning, an acquisition channel, activation, pricing, or the sales motion. Then I fix it as a senior PMM leader, but without the full-time bet.</p>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:16px;margin-top:32px;">
        <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="font-size:18px;padding:17px 32px;box-shadow:0 6px 22px rgba(27,42,107,0.28);">Book a call</a>
        <span style="font-size:14px;color:var(--ink-mute);line-height:1.4;max-width:220px;">A 20-minute call, no pitch. You'll leave with a clear first move.</span>
      </div>
    </div>

    <!-- funnel visual -->
    <div>
      <span class="handwritten" style="display:block;text-align:center;font-size:24px;margin-bottom:6px;color:var(--navy);">Where are you losing users?</span>
      <div class="funnel-wrap">
        <svg viewBox="0 0 320 332" width="100%" height="100%" style="display:block;overflow:visible;" role="img" aria-labelledby="funnel-title">
          <title id="funnel-title">Growth funnel showing where users drop off across acquisition, activation, monetisation, and retention.</title>
          <defs>
            <linearGradient id="funnelAurora" x1="0" y1="0" x2="0" y2="320" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#7a5cc0" />
              <stop offset="0.55" stop-color="#1b2a6b" />
              <stop offset="1" stop-color="#1f8a66" />
            </linearGradient>
            <linearGradient id="funnelShade" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#000" stop-opacity="0.24" />
              <stop offset="0.32" stop-color="#000" stop-opacity="0" />
              <stop offset="0.7" stop-color="#fff" stop-opacity="0" />
              <stop offset="1" stop-color="#fff" stop-opacity="0.18" />
            </linearGradient>
            <filter id="funnelGlow" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="18" /></filter>
          </defs>
          <ellipse cx="150" cy="118" rx="110" ry="140" fill="#6b4fa0" opacity="0.20" filter="url(#funnelGlow)" />
          <ellipse cx="172" cy="250" rx="86" ry="76" fill="#1f8a66" opacity="0.20" filter="url(#funnelGlow)" />

          <ellipse cx="160" cy="28" rx="132" ry="22" fill="#3a2d63" />

          <path d="M28,28 A132,22 0 0 1 292,28 L263,114 A103,17.5 0 0 0 57,114 Z" fill="url(#funnelAurora)" />
          <path d="M28,28 A132,22 0 0 1 292,28 L263,114 A103,17.5 0 0 0 57,114 Z" fill="url(#funnelShade)" />
          <path d="M57,114 A103,17.5 0 0 1 263,114 L235,194 A75,12.5 0 0 0 85,194 Z" fill="url(#funnelAurora)" />
          <path d="M57,114 A103,17.5 0 0 1 263,114 L235,194 A75,12.5 0 0 0 85,194 Z" fill="url(#funnelShade)" />
          <path d="M85,194 A75,12.5 0 0 1 235,194 L209,264 A49,8.5 0 0 0 111,264 Z" fill="url(#funnelAurora)" />
          <path d="M85,194 A75,12.5 0 0 1 235,194 L209,264 A49,8.5 0 0 0 111,264 Z" fill="url(#funnelShade)" />
          <path d="M111,264 A49,8.5 0 0 1 209,264 L186,320 A26,4.5 0 0 0 134,320 Z" fill="url(#funnelAurora)" />
          <path d="M111,264 A49,8.5 0 0 1 209,264 L186,320 A26,4.5 0 0 0 134,320 Z" fill="url(#funnelShade)" />

          <path d="M28,28 A132,22 0 0 0 292,28" fill="none" stroke="#fff" stroke-opacity="0.32" stroke-width="1.4" />
          <path d="M57,114 A103,17.5 0 0 1 263,114" fill="none" stroke="#fff" stroke-opacity="0.26" stroke-width="1.3" />
          <path d="M85,194 A75,12.5 0 0 1 235,194" fill="none" stroke="#fff" stroke-opacity="0.24" stroke-width="1.3" />
          <path d="M111,264 A49,8.5 0 0 1 209,264" fill="none" stroke="#fff" stroke-opacity="0.22" stroke-width="1.3" />

          <!-- balls flow down the funnel: they enter wide at the rim, converge toward the spout -->
          <g>
            <circle r="4.6" fill="#fff" opacity="0">
              <animateMotion path="M150,46 C153,130 159,240 160,316" dur="4.2s" begin="0s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.78;0.78;0" keyTimes="0;0.12;0.86;1" dur="4.2s" begin="0s" repeatCount="indefinite"/>
            </circle>
            <circle r="4.2" fill="#fff" opacity="0">
              <animateMotion path="M160,42 C160,140 160,250 160,316" dur="4.2s" begin="0.85s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.72;0.72;0" keyTimes="0;0.12;0.86;1" dur="4.2s" begin="0.85s" repeatCount="indefinite"/>
            </circle>
            <circle r="4.6" fill="#fff" opacity="0">
              <animateMotion path="M171,48 C167,130 161,240 160,316" dur="4.2s" begin="1.7s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.78;0.78;0" keyTimes="0;0.12;0.86;1" dur="4.2s" begin="1.7s" repeatCount="indefinite"/>
            </circle>
            <circle r="4" fill="#fff" opacity="0">
              <animateMotion path="M156,44 C158,150 160,255 160,316" dur="4.2s" begin="2.55s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.7;0.7;0" keyTimes="0;0.12;0.86;1" dur="4.2s" begin="2.55s" repeatCount="indefinite"/>
            </circle>
            <circle r="4.3" fill="#fff" opacity="0">
              <animateMotion path="M165,46 C163,150 160,255 160,316" dur="4.2s" begin="3.4s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.74;0.74;0" keyTimes="0;0.12;0.86;1" dur="4.2s" begin="3.4s" repeatCount="indefinite"/>
            </circle>
          </g>
          <!-- leaks: balls that drop off at different stages and fall out of the funnel -->
          <g>
            <circle r="3.6" fill="#ec6a43" opacity="0">
              <animateMotion path="M150,100 C122,106 82,120 50,172" dur="3.3s" begin="1.1s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.92;0.85;0" keyTimes="0;0.16;0.7;1" dur="3.3s" begin="1.1s" repeatCount="indefinite"/>
            </circle>
            <circle r="3.4" fill="#ec6a43" opacity="0">
              <animateMotion path="M168,178 C192,188 214,202 232,250" dur="3.5s" begin="2.3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.92;0.85;0" keyTimes="0;0.16;0.7;1" dur="3.5s" begin="2.3s" repeatCount="indefinite"/>
            </circle>
            <circle r="3.2" fill="#ec6a43" opacity="0">
              <animateMotion path="M151,248 C137,258 121,274 107,314" dur="3.6s" begin="3.5s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.92;0.85;0" keyTimes="0;0.16;0.7;1" dur="3.6s" begin="3.5s" repeatCount="indefinite"/>
            </circle>
          </g>

          <text x="160" y="80" text-anchor="middle" fill="#fff" font-size="13" font-weight="700" font-family="Inter">Acquisition</text>
          <text x="160" y="160" text-anchor="middle" fill="#fff" font-size="13" font-weight="700" font-family="Inter">Activation</text>
          <text x="160" y="234" text-anchor="middle" fill="#fff" font-size="13" font-weight="700" font-family="Inter">Monetisation</text>
          <text x="160" y="298" text-anchor="middle" fill="#fff" font-size="12" font-weight="700" font-family="Inter">Retention</text>
        </svg>
      </div>
    </div>
  </div>
</header>

<!-- LOGO STRIP -->
<section style="background:var(--cream);border-top:1px solid var(--warm-line);border-bottom:1px solid var(--warm-line);">
  <div style="max-width:1240px;margin:0 auto;padding:28px 24px;display:flex;align-items:center;gap:32px;flex-wrap:wrap;">
    <span style="font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#726551;white-space:nowrap;">Past experience</span>
    <div style="flex:1;min-width:260px;display:flex;gap:28px;flex-wrap:wrap;align-items:center;">
      <span style="font-size:15px;font-weight:800;letter-spacing:-0.3px;color:#8a7d6e;">Fi Money</span>
      <img src="/logos/practo.png" alt="Practo" width="80" height="22" loading="lazy" decoding="async" style="height:22px;width:auto;filter:grayscale(1);opacity:0.75;" />
      <img src="/logos/makemytrip.svg" alt="MakeMyTrip" width="96" height="26" loading="lazy" decoding="async" style="height:26px;width:auto;filter:grayscale(1);opacity:0.75;" />
      <span style="font-size:15px;font-weight:800;letter-spacing:-0.3px;color:#8a7d6e;">Raymond</span>
      <span style="font-size:15px;font-weight:800;letter-spacing:-0.3px;color:#8a7d6e;">TCS</span>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" style="background:var(--canvas);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div style="max-width:760px;">
      <span class="handwritten" style="font-size:24px;display:block;">PMM, as a service</span>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:10px 0 0;">I plug in where your team needs me, starting with growth.</h2>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;">Most teams bring me in to own their growth strategy, then pull in for positioning or go-to-market when the work calls for it.</p>
    </div>
    <div style="max-width:880px;margin-top:32px;">
      <div class="module module--featured">
        <span class="sticky-tag gold" style="position:absolute;top:-14px;left:24px;">where most teams start</span>
        <div class="module-head">
          <span class="module-icon" style="background:#fdeee9;">📈</span>
          <h3 class="module-title" style="font-size:24px;">Growth strategy</h3>
        </div>
        <p class="module-desc" style="margin-bottom:18px;font-size:16px;">The core of most engagements. A channel mix sized to your stage and run as experiments, so spend follows what's working.</p>
        <div class="channel-grid">
            <div class="channel-card">
              <span style="font-size:18px;flex:none;">💸</span>
              <div>
                <p style="font-weight:700;font-size:14px;margin:0;">Paid acquisition</p>
                <p style="font-size:13px;color:var(--ink-mute);margin:2px 0 0;line-height:1.4;">Channel-level CAC, creative testing, and spend that maps to qualified pipeline.</p>
              </div>
            </div>
            <div class="channel-card">
              <span style="font-size:18px;flex:none;">🌱</span>
              <div>
                <p style="font-weight:700;font-size:14px;margin:0;">Organic and SEO</p>
                <p style="font-size:13px;color:var(--ink-mute);margin:2px 0 0;line-height:1.4;">Content and search that compounds, built on the sharpened positioning.</p>
              </div>
            </div>
            <div class="channel-card">
              <span style="font-size:18px;flex:none;">🔄</span>
              <div>
                <p style="font-weight:700;font-size:14px;margin:0;">Lifecycle and retention</p>
                <p style="font-size:13px;color:var(--ink-mute);margin:2px 0 0;line-height:1.4;">Onboarding, activation, and churn work, the stages that quietly cap growth.</p>
              </div>
            </div>
            <div class="channel-card">
              <span style="font-size:18px;flex:none;">🧪</span>
              <div>
                <p style="font-weight:700;font-size:14px;margin:0;">Experimentation</p>
                <p style="font-size:13px;color:var(--ink-mute);margin:2px 0 0;line-height:1.4;">A test cadence across the funnel, so the channel mix stays healthy.</p>
              </div>
            </div>
          </div>
        </div>
      <p class="handwritten" style="font-size:22px;margin:38px 0 0;color:var(--navy);">need other services?</p>
      <div class="other-services" style="margin-top:14px;">
        <div class="module">
          <div class="module-head">
            <span class="module-icon" style="background:#fdf3da;">🎯</span>
            <h3 class="module-title">Positioning and messaging audit</h3>
          </div>
          <p class="module-desc">When the market moved and your story stayed put. Repositioning to stay relevant, with the proof stack built underneath it.</p>
        </div>
        <div class="module">
          <div class="module-head">
            <span class="module-icon" style="background:#e6f0ff;">🤝</span>
            <h3 class="module-title">Go-to-market (GTM) strategy</h3>
          </div>
          <p class="module-desc">When your sharpened story needs to reach buyers. Segmentation, ICP, sales enablement, launch playbooks, pricing and packaging.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how-it-works" style="background:var(--cream);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div style="max-width:720px;">
      <span class="handwritten" style="font-size:24px;display:block;">how we'd actually work</span>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:10px 0 0;">From first call to shipped fix, here's how it goes.</h2>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;">No open-ended retainer, no decks. We find the constraint, agree on the first fix, and I do the work as part of your team.</p>
    </div>
    <div class="process-grid">
      <div class="process-step">
        <span class="process-num">1</span>
        <p class="process-when">Week 1 to 2</p>
        <h3 class="process-title">Find the constraint</h3>
        <p class="process-desc">I understand the company, users, and the growth funnel. You get a report on what's actually capping growth, whether that's positioning, an acquisition channel, activation, pricing, or the sales motion.</p>
      </div>
      <div class="process-step">
        <span class="process-num">2</span>
        <p class="process-when">Week 3 onward</p>
        <h3 class="process-title">Ship the fix</h3>
        <p class="process-desc">We agree on the first move and I build it. Messaging, landing pages, lifecycle, enablement, whatever the fix needs. Two to three working sessions a week, execution in between.</p>
      </div>
      <div class="process-step">
        <span class="process-num">3</span>
        <p class="process-when">Ongoing</p>
        <h3 class="process-title">Scale the growth</h3>
        <p class="process-desc">I stay close as your fractional head of PMM, month to month. When the work's done, we stop.</p>
      </div>
    </div>
    <div style="margin-top:32px;">
      <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="font-size:16px;padding:15px 30px;">Book a call</a>
    </div>
  </div>
</section>

<!-- PROOF -->
<section id="proof" style="background:var(--blue-tint);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div style="max-width:720px;">
      <span class="handwritten" style="font-size:24px;display:block;">does it actually work?</span>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:10px 0 0;">12+ years, and the numbers to prove it.</h2>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;">Across Fi Money, Practo, MakeMyTrip, and Raymond. Every number here is from real work.</p>
    </div>
    <div class="proof-strip">
      <div class="proof-stat">
        <span style="font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:var(--ink-mute);">Growth &amp; experimentation</span>
        <div style="font-size:46px;font-weight:800;color:var(--navy);line-height:1;letter-spacing:-1px;margin-top:10px;">$11M+</div>
        <p style="font-weight:700;font-size:16px;margin:16px 0 4px;">Annual revenue generated</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">From a structured experimentation program across savings, lending and investment products at a Series C neobank.</p>
      </div>
      <div class="proof-stat">
        <span style="font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:var(--ink-mute);">Paid acquisition turnaround</span>
        <div style="font-size:46px;font-weight:800;color:var(--navy);line-height:1;letter-spacing:-1px;margin-top:10px;">7.35x</div>
        <p style="font-weight:700;font-size:16px;margin:16px 0 4px;">on incremental spend</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">Overhauled paid acquisition. Channel mix, targeting, spend efficiency. Turned a loss-making channel profitable in four months and scaled it to the best contribution-margin run on record, for Series E healthtech startup.</p>
      </div>
      <div class="proof-stat">
        <span style="font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:var(--ink-mute);">Positioning &amp; enablement</span>
        <div style="font-size:46px;font-weight:800;color:var(--navy);line-height:1;letter-spacing:-1px;margin-top:10px;">25%</div>
        <p style="font-weight:700;font-size:16px;margin:16px 0 4px;">Qualified conversion lift</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">After repositioning a salary product with persona battlecards, objection-handling, and maturity-based messaging for CHROs and founders.</p>
      </div>
    </div>
    <div class="proof-bottom" style="background:#fff;border-radius:16px;padding:36px 40px;margin-top:18px;border:1px solid var(--hairline);display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;">
      <div>
        <span style="font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:var(--ink-mute);">Launch &amp; GTM</span>
        <div style="font-size:42px;font-weight:800;color:var(--navy);line-height:1;letter-spacing:-1px;margin-top:10px;">10 days</div>
        <p style="font-weight:700;font-size:16px;margin:12px 0 4px;">To market, 0-to-1</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">A new category launched from scratch: a city pilot, then a national rollout.</p>
      </div>
      <div style="border-left:1px solid var(--hairline);padding-left:32px;">
        <p style="font-size:13px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:var(--ink-mute);margin:0 0 12px;">Also on record</p>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:14px;color:var(--ink-mute);">
          <p style="margin:0;"><strong style="color:var(--ink);">40% fewer uninstalls</strong> and 15% higher stickiness from an in-app lifecycle feature, for traveltech startup</p>
          <p style="margin:0;"><strong style="color:var(--ink);">2&times; quarterly SQL targets</strong> through integrated demand gen across LinkedIn, Google, and Meta</p>
          <p style="margin:0;"><strong style="color:var(--ink);">30% faster time-to-market</strong> on new launch playbooks</p>
        </div>
      </div>
    </div>

    <!-- RECOGNITION -->
