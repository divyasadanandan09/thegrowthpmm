---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
const BOOKING = "https://calendar.app.google/LXLo1623kmwa7NWr6";
// TODO: replace with the real Growth Audit Google Form URL before launch.
const DIAGNOSTIC = "https://forms.gle/HTwdNSTiyyXQYsxb7";
---

<Layout>

<!-- NAV: full bar at top of page, collapses to a corner CTA on scroll -->
<div class="nav-wrap" id="nav-top">
  <div id="navbar">
    <a href="#top" style="display:flex;align-items:center;flex:none;text-decoration:none;">
      <Logo size={28} wordSize={16} />
    </a>
    <div id="nav-links">
      <a href="#services">Services</a>
      <a href="#report">Free Growth Audit</a>
      <a href="#about">About me</a>
    </div>
    <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="font-size:13px;padding:9px 16px;flex:none;white-space:nowrap;">Book free consultation</a>
    <button id="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2 5h16M2 10h16M2 15h16" stroke="#16180f" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>
</div>
<div id="mobile-menu">
  <a href="#services">Services</a>
  <a href="#report">Free Growth Audit</a>
  <a href="#about">About me</a>
  <a href="#proof">Proof</a>
  <a href="/ai-product-marketing">AI PMM</a>
  <a href="/faq">FAQ</a>
  <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="text-align:center;margin-top:8px;padding:12px;">Book free consultation</a>
</div>
<div id="nav-cta-corner">
  <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy">Book free consultation</a>
</div>
<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!isOpen));
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => menu.classList.remove("open"))
  );
  const onScroll = () => {
    document.body.classList.toggle("scrolled", window.scrollY > 80);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>

<main>
<!-- HERO -->
<header id="top" class="grid-canvas" style="background:var(--hero-bg);position:relative;overflow:hidden;">
  <div class="hero-grid" style="max-width:1240px;margin:0 auto;padding:140px 24px 80px;display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center;position:relative;">
    <div>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px;">
        <span class="sticky-tag purple">Only 3 clients per month</span>
      </div>
      <h1 style="font-size:42px;font-weight:800;line-height:1.12;letter-spacing:-1.1px;margin:0;color:var(--ink);">The Product Marketing leader you need, <span class="marker">before you're ready to hire one</span>.</h1>
      <p style="font-size:20px;font-weight:600;line-height:1.4;color:var(--ink);margin:18px 0 0;max-width:560px;">You've built a product customers pay for. Now let's build predictable growth.</p>
      <p style="font-size:17px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;max-width:560px;">I partner with post-product-market-fit startups to build the positioning, messaging, and GTM that turn early traction into scalable growth, without the cost of a full-time hire.</p>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:16px;margin-top:32px;">
        <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="font-size:16px;padding:14px 26px;box-shadow:0 6px 22px rgba(22,24,15,0.22);">Book free consultation</a>
        <span style="font-size:14px;color:var(--ink-mute);line-height:1.4;max-width:220px;">A 20-minute call. You'll leave with a clear first move.</span>
      </div>
    </div>

    <!-- positioning diagram: PMM as the connective function between PMF and scalable growth -->
    <div>
      <div class="diagram-wrap">
        <svg viewBox="0 0 420 410" width="100%" height="100%" style="display:block;overflow:visible;" role="img" aria-labelledby="diagram-title">
          <title id="diagram-title">Diagram: Product, Sales, and Marketing connected by The Growth PMM as the missing function between product-market fit and scalable growth.</title>
          <defs>
            <filter id="hubShadow" x="-40%" y="-60%" width="180%" height="220%">
              <feDropShadow dx="0" dy="7" stdDeviation="12" flood-color="#16180f" flood-opacity="0.16" />
            </filter>
          </defs>

          <!-- connectors: hub -> each team (drawn first so chips/badge sit on top) -->
          <path d="M210,164 C210,132 210,108 210,80" fill="none" stroke="#16180f" stroke-opacity="0.28" stroke-width="1.4" stroke-linecap="round" />
          <path d="M162,212 C138,244 120,266 108,290" fill="none" stroke="#16180f" stroke-opacity="0.28" stroke-width="1.4" stroke-linecap="round" />
          <path d="M258,212 C282,244 300,266 312,290" fill="none" stroke="#16180f" stroke-opacity="0.28" stroke-width="1.4" stroke-linecap="round" />

          <circle cx="210" cy="80" r="3" fill="#16180f" />
          <circle cx="108" cy="290" r="3" fill="#16180f" />
          <circle cx="312" cy="290" r="3" fill="#16180f" />

          <!-- three team chips (transparent, outline only) -->
          <rect x="162" y="44" width="96" height="36" rx="18" fill="none" stroke="#5f6470" stroke-opacity="0.4" stroke-width="1.2" />
          <rect x="50" y="292" width="80" height="36" rx="18" fill="none" stroke="#5f6470" stroke-opacity="0.4" stroke-width="1.2" />
          <rect x="274" y="292" width="112" height="36" rx="18" fill="none" stroke="#5f6470" stroke-opacity="0.4" stroke-width="1.2" />
          <text x="210" y="67" text-anchor="middle" font-family="Inter" font-size="13.5" font-weight="700" fill="#16180f">Product</text>
          <text x="90" y="315" text-anchor="middle" font-family="Inter" font-size="13.5" font-weight="700" fill="#16180f">Sales</text>
          <text x="330" y="315" text-anchor="middle" font-family="Inter" font-size="13.5" font-weight="700" fill="#16180f">Marketing</text>

          <!-- hub: The Growth PMM (the missing piece) -->
          <g transform="rotate(-2 210 190)">
            <rect x="120" y="164" width="180" height="52" rx="15" fill="#DBFF00" stroke="#16180f" stroke-width="1.4" filter="url(#hubShadow)" />
            <text x="210" y="196" text-anchor="middle" font-family="Bricolage Grotesque, Inter" font-size="19" font-weight="800" letter-spacing="-0.4" fill="#16180f">The Growth PMM</text>
          </g>

          <!-- handwritten annotation + curly two-loop hand-drawn arrow (kept clear of the pill + labels, sits in the open wedge above-right) -->
          <text x="344" y="120" text-anchor="middle" font-family="'Caveat', cursive" font-size="23" font-weight="700" fill="#16180f" transform="rotate(-6 344 120)">the missing piece</text>
          <path d="M356,134 C368,140 366,154 354,154 C344,154 346,140 358,142 C370,144 368,160 354,164 C340,168 322,168 306,167" fill="none" stroke="#16180f" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M306,167 L315,166 M306,167 L310,174" fill="none" stroke="#16180f" stroke-width="1.6" stroke-linecap="round" />

          <!-- caption: same handwritten voice, so it reads with the annotation -->
          <text x="210" y="384" text-anchor="middle" font-family="'Caveat', cursive" font-size="21" font-weight="700" fill="#16180f">Between product-market fit and scalable growth.</text>
        </svg>
      </div>
    </div>
  </div>
</header>

<!-- LOGO STRIP -->
<section style="background:var(--cream);border-top:1px solid var(--warm-line);border-bottom:1px solid var(--warm-line);">
  <div style="max-width:1240px;margin:0 auto;padding:28px 24px;display:flex;align-items:center;gap:32px;flex-wrap:wrap;">
    <span style="font-size:12px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#726551;white-space:nowrap;">Past experience</span>
    <div style="flex:1;min-width:260px;display:flex;gap:28px;flex-wrap:wrap;align-items:center;">
      <img src="/logos/fi-money.svg" alt="Fi Money" width="22" height="22" loading="lazy" decoding="async" style="height:22px;width:22px;filter:grayscale(1);opacity:0.75;" />
      <img src="/logos/practo.png" alt="Practo" width="80" height="22" loading="lazy" decoding="async" style="height:22px;width:auto;filter:grayscale(1);opacity:0.75;" />
      <img src="/logos/makemytrip.svg" alt="MakeMyTrip" width="96" height="26" loading="lazy" decoding="async" style="height:26px;width:auto;filter:grayscale(1);opacity:0.75;" />
      <img src="/logos/raymond.png" alt="Raymond" width="65" height="22" loading="lazy" decoding="async" style="height:22px;width:auto;filter:grayscale(1);opacity:0.75;" />
      <img src="/logos/tcs.png" alt="TCS" width="77" height="22" loading="lazy" decoding="async" style="height:22px;width:auto;filter:grayscale(1);opacity:0.75;" />
    </div>
  </div>
</section>

<!-- PROBLEM -> TRANSFORMATION: the complexity shift resolved by the before/after -->
<section style="background:var(--cream);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:0;">Growth didn't get harder. Your company got more complex.</h2>
      <p style="font-size:19px;line-height:1.6;color:var(--ink-mute);margin:22px 0 0;">When you're building toward product-market fit, founders own positioning, messaging, launches, and GTM. As you scale, those jobs get too interconnected to stay founder-led, and <span class="marker">nobody owns the story that connects them</span>. That's when growth slows.</p>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-deep);font-weight:600;margin:26px 0 0;">Here's the shift once Product Marketing has an owner.</p>
    </div>
    <div class="ba-table">
      <div class="ba-row ba-head">
        <div class="ba-before">Before</div>
        <div class="ba-after">After</div>
      </div>
      <div class="ba-row">
        <div class="ba-before">Founder owns positioning</div>
        <div class="ba-after">Clear PMM ownership</div>
      </div>
      <div class="ba-row">
        <div class="ba-before">Every launch is improvised</div>
        <div class="ba-after">A repeatable launch process</div>
      </div>
      <div class="ba-row">
        <div class="ba-before">Sales writes its own messaging</div>
        <div class="ba-after">One consistent narrative</div>
      </div>
      <div class="ba-row">
        <div class="ba-before">Product builds without GTM input</div>
        <div class="ba-after">Product and GTM move together</div>
      </div>
      <div class="ba-row">
        <div class="ba-before">Growth decisions are reactive</div>
        <div class="ba-after">A prioritized growth roadmap</div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES: what we'll build together -->
<section id="services" style="background:var(--canvas);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div>
      <span class="handwritten" style="font-size:24px;display:block;">the work itself</span>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:8px 0 0;">What we'll build together.</h2>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;max-width:820px;">Four foundations that turn early traction into growth you can repeat.</p>
    </div>
    <div style="margin-top:36px;">
      <div class="module module--featured">
        <span class="sticky-tag gold" style="position:absolute;top:-14px;left:24px;">the outcome we build toward</span>
        <div class="module-head">
          <span class="module-icon" style="background:#eef6c8;" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16180f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18l5-5 3 3 7-8"/><path d="M17 8h4v4"/></svg>
          </span>
          <h3 class="module-title" style="font-size:24px;">A repeatable growth engine</h3>
        </div>
        <p class="module-desc" style="font-size:16px;">Prioritize the highest-impact opportunities across activation, lifecycle, experimentation, and GTM, so growth becomes intentional, not reactive. The three foundations below are how we get there.</p>
      </div>
      <div class="other-services" style="grid-template-columns:repeat(3,1fr);margin-top:18px;">
        <div class="module">
          <div class="module-head">
            <span class="module-icon" style="background:#eef6c8;" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16180f" stroke-width="1.8"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/></svg>
            </span>
            <h3 class="module-title">Positioning customers instantly understand</h3>
          </div>
          <p class="module-desc">We'll define exactly who you're for, why customers choose you, and how to communicate your value consistently across every touchpoint.</p>
        </div>
        <div class="module">
          <div class="module-head">
            <span class="module-icon" style="background:#eef6c8;" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16180f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V5"/><path d="M6 11l6-6 6 6"/></svg>
            </span>
            <h3 class="module-title">Product launches that drive adoption</h3>
          </div>
          <p class="module-desc">Move beyond feature announcements with launch strategies that create customer understanding, internal alignment, and measurable business impact.</p>
        </div>
        <div class="module">
          <div class="module-head">
            <span class="module-icon" style="background:#eef6c8;" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16180f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14a2 2 0 0 1-2 2H9l-4 3V6a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2z"/></svg>
            </span>
            <h3 class="module-title">Messaging that helps Sales close faster</h3>
          </div>
          <p class="module-desc">Equip your team with messaging, competitive positioning, and sales enablement that turns customer conversations into revenue.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how-it-works" style="background:var(--cream);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:0;">How we'd actually work.</h2>
      <p style="font-size:15px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;max-width:1150px;">Diagnose the constraint, build the foundation, then embed it with your team. Practical recommendations, not a deck that sits unused.</p>
    </div>
    <div class="process-grid">
      <div class="process-step">
        <p class="process-when">Step 1</p>
        <h3 class="process-title">Understand your growth constraints</h3>
        <p class="process-desc">We review your customers, positioning, messaging, funnel, GTM motion, and business goals to identify where growth is slowing.</p>
      </div>
      <div class="process-step">
        <p class="process-when">Step 2</p>
        <h3 class="process-title">Build the Product Marketing foundation</h3>
        <p class="process-desc">Together we'll prioritize the positioning, launches, messaging, and growth initiatives that create the biggest business impact.</p>
      </div>
      <div class="process-step">
        <p class="process-when">Step 3</p>
        <h3 class="process-title">Enable your team to scale</h3>
        <p class="process-desc">I work alongside Product, Sales, and Marketing to ensure every initiative is adopted, measured, and continuously improved.</p>
      </div>
    </div>
    <div style="margin-top:32px;">
      <a href={BOOKING} target="_blank" rel="noopener" class="btn-navy" style="font-size:16px;padding:14px 26px;">Book free consultation</a>
    </div>
  </div>
</section>

<!-- PROOF -->
<section id="proof" style="background:var(--blue-tint);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:0;">The impact of 12+ years of <span class="marker">better Product Marketing</span>.</h2>
      <p style="font-size:18px;line-height:1.6;color:var(--ink-mute);margin:16px 0 0;max-width:820px;">Across multiple high-growth companies like Fi Money, Practo, MakeMyTrip, and Raymond.</p>
    </div>
    <div class="proof-strip">
      <div class="proof-stat">
        <span style="font-size:13px;font-weight:700;color:var(--ink-mute);">Growth &amp; experimentation</span>
        <div style="font-size:46px;font-weight:800;color:var(--ink-deep);line-height:1;letter-spacing:-1px;margin-top:10px;">$11M+</div>
        <p style="font-weight:700;font-size:16px;margin:16px 0 4px;">Annual revenue</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">Generated through experimentation programs across lending, investments and savings at a Series C neobank.</p>
      </div>
      <div class="proof-stat">
        <span style="font-size:13px;font-weight:700;color:var(--ink-mute);">Paid acquisition turnaround</span>
        <div style="font-size:46px;font-weight:800;color:var(--ink-deep);line-height:1;letter-spacing:-1px;margin-top:10px;">7.35x</div>
        <p style="font-weight:700;font-size:16px;margin:16px 0 4px;">on incremental spend</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">Overhauled paid acquisition. Channel mix, targeting, spend efficiency. Turned a loss-making channel profitable in four months, for a Series E healthtech startup.</p>
      </div>
      <div class="proof-stat">
        <span style="font-size:13px;font-weight:700;color:var(--ink-mute);">Positioning &amp; enablement</span>
        <div style="font-size:46px;font-weight:800;color:var(--ink-deep);line-height:1;letter-spacing:-1px;margin-top:10px;">25%</div>
        <p style="font-weight:700;font-size:16px;margin:16px 0 4px;">Qualified conversion lift</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">After repositioning a salary product with persona battlecards, objection-handling, and maturity-based messaging for CHROs and founders.</p>
      </div>
    </div>
    <div class="proof-bottom" style="background:#fff;border-radius:16px;padding:36px 40px;margin-top:18px;border:1px solid var(--hairline);display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;">
      <div>
        <span style="font-size:13px;font-weight:700;color:var(--ink-mute);">Launch &amp; GTM</span>
        <div style="font-size:42px;font-weight:800;color:var(--ink-deep);line-height:1;letter-spacing:-1px;margin-top:10px;">10 days</div>
        <p style="font-weight:700;font-size:16px;margin:12px 0 4px;">To market, 0-to-1</p>
        <p style="font-size:14px;color:var(--ink-mute);margin:0;">A new category launched from scratch: a city pilot, then a national rollout.</p>
      </div>
      <div style="border-left:1px solid var(--hairline);padding-left:32px;">
        <p style="font-size:13px;font-weight:700;color:var(--ink-mute);margin:0 0 12px;">Also on record</p>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:14px;color:var(--ink-mute);">
          <p style="margin:0;"><strong style="color:var(--ink);">40% fewer uninstalls</strong> and 15% higher stickiness from an in-app lifecycle feature, for traveltech startup</p>
          <p style="margin:0;"><strong style="color:var(--ink);">2&times; quarterly SQL targets</strong> through integrated demand gen across LinkedIn, Google, and Meta</p>
          <p style="margin:0;"><strong style="color:var(--ink);">30% faster time-to-market</strong> on new launch playbooks</p>
        </div>
      </div>
    </div>

    <!-- RECOGNITION -->
    <div class="recognition-band" style="margin-top:18px;background:var(--ink-deep);border-radius:16px;padding:36px 40px;display:flex;flex-wrap:wrap;align-items:center;gap:32px;">
      <span class="sticky-tag purple" style="font-size:13px;padding:9px 18px;transform:rotate(-2deg);flex:none;">Recognition</span>
      <div style="flex:1;min-width:220px;display:flex;align-items:center;gap:14px;">
        <span style="flex:none;line-height:0;" aria-hidden="true"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#DBFF00" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 5H4v2a3 3 0 0 0 3 3M17 5h3v2a3 3 0 0 1-3 3"/><path d="M10 13.5V17H9a2 2 0 0 0-2 2h10a2 2 0 0 0-2-2h-1v-3.5"/></svg></span>
        <div>
          <p style="font-size:22px;font-weight:800;color:#fff;margin:0;letter-spacing:-0.3px;">Top 100 Product Marketing Influencer globally</p>
          <p style="font-size:14px;color:var(--on-navy-mute);margin:4px 0 0;">Product Marketing Alliance, 2025</p>
        </div>
      </div>
      <div style="height:36px;width:1px;background:var(--navy-tint);flex:none;"></div>
      <div style="flex:1;min-width:200px;display:flex;align-items:center;gap:10px;">
        <span style="flex:none;line-height:0;" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DBFF00" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19l5-5 3 3 8-9"/><path d="M16 8h4v4"/></svg></span>
        <div>
          <p style="font-size:15px;font-weight:700;color:#fff;margin:0;">Master of Margin Award</p>
          <p style="font-size:13px;color:var(--on-navy-mute);margin:4px 0 0;">For the strongest contribution-margin quarter on record, at Practo</p>
        </div>
      </div>
      <div style="flex:1;min-width:200px;display:flex;align-items:center;gap:10px;">
        <span style="flex:none;line-height:0;" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DBFF00" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9z"/></svg></span>
        <div>
          <p style="font-size:15px;font-weight:700;color:#fff;margin:0;">Spot Award, twice over</p>
          <p style="font-size:13px;color:var(--on-navy-mute);margin:4px 0 0;">For AI-native lifecycle workflows adopted as the org standard, at Fi Money.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section id="testimonials" style="background:var(--canvas);">
  <div style="max-width:1240px;margin:0 auto;padding:92px 24px;">
    <div>
      <h2 style="font-size:42px;font-weight:800;line-height:1.14;letter-spacing:-0.9px;margin:0;max-width:900px;">Trusted by founders and growth teams.</h2>
    </div>
    <div class="testimonials">
